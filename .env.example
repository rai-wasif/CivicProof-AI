# CivicProof AI can run without an API key using local deterministic rules.
# Add one provider only when you want stronger generated drafts.

# Text provider: local, groq, openai, or gemini
CIVICPROOF_LLM_PROVIDER=local

# Groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash

# Optional storage overrides
CIVICPROOF_DATA_DIR=
CIVICPROOF_REPORTS_DIR=
